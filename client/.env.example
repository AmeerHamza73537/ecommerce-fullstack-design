# Base URL of the backend API. Copy this file to .env.
VITE_API_URL=http://localhost:5000

# Cloudinary — for uploading product images from the Admin Panel (unsigned upload).
# Create an "unsigned" upload preset in your Cloudinary dashboard, then fill these in.
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
