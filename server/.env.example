# Copy this file to .env and fill in your own values.
PORT=5000

# MongoDB connection string.
MONGO_URL=

# Secret used to sign JWT auth tokens — set this to any long random string.
JWT_SECRET=

# Hardcoded admin credentials — only one admin, no signup flow.
# The admin logs in via POST /api/admin/login with these exact values.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Cloudinary configuration (if needed by backend in the future)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=

